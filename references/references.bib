  abstract = {{Transformers are powerful sequence models, but require time and memory that grows quadratically with the sequence length. In this paper we introduce sparse factorizations of the attention matrix which reduce this to $O(n \sqrt(n))$. We also introduce a) a variation on architecture and initialization to train deeper networks}},
  author = {Rewon Child and Scott Gray and Alec Radford and Ilya Sutskever},
