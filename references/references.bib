  abstract = {"This text introduces decision making under uncertainty from a computational perspective and provides an overview of the methods for building autonomous and decision-support systems"-- Provided by publisher. Table of contents:P︣︣robabilistic reasoning; Sequential problems; Model uncertainty; State uncertainty; Multiagent systems.},
  author = {Mykel J.. Kochenderfer and Tim A.. Wheeler and Kyle H.. Wray},
